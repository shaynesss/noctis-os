# Noctis OS frontend — environment variables
# Copy to .env and fill in real values. Never commit .env itself.
# Vite only exposes VITE_-prefixed vars to client code (see src/api.ts).

# Backend base URL. Local-only per SPEC.md ("Any deployment — local-only").
VITE_API_BASE=http://localhost:8000

# Must match the backend's NOCTIS_API_TOKEN (see ../.env.example). Embedding
# it in the frontend bundle is acceptable here since this app never deploys
# past localhost.
VITE_API_TOKEN=
