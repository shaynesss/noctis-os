# Secrets
.env

# Python
__pycache__/
*.pyc
backend/.venv/
backend/venv/

# Node
node_modules/
dist/
dist-ssr/
*.local

# Impeccable live-mode runtime journal (local recovery state, not project source)
.impeccable/live/sessions/

# Hook-driven action-feed logs (backend/hooks/log_action.py) -- high-churn,
# ephemeral, explicitly NOT vault content. See SPEC.md EDD "State files".
backend/runtime/*.log

# A Dev-mode launch writes a per-project local hook registration here (see
# launch_surfaces._ensure_dev_hooks) -- local machine state, not source.
.claude/settings.local.json

# Claude Code's own runtime state accumulates here once this dir is used as
# CLAUDE_CONFIG_DIR for a non-dev launch (see session.py) -- only CLAUDE.md
# is source, everything else is generated session/cache state.
backend/launch_config/nondev/.claude.json
backend/launch_config/nondev/.last-cleanup
backend/launch_config/nondev/.last-update-result.json
backend/launch_config/nondev/backups/
backend/launch_config/nondev/cache/
backend/launch_config/nondev/history.jsonl
backend/launch_config/nondev/mcp-needs-auth-cache.json
backend/launch_config/nondev/plugins/
backend/launch_config/nondev/projects/
backend/launch_config/nondev/sessions/
backend/launch_config/nondev/settings.json

# OS
.DS_Store
