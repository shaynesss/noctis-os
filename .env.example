# Noctis OS backend — environment variables
# Copy to .env and fill in real values. Never commit .env itself.

# Bearer token required on every backend route (SPEC.md EDD: "Backend auth is mandatory, not optional" —
# localhost binding alone isn't sufficient, CSRF/DNS-rebinding class of attack).
NOCTIS_API_TOKEN=

# Absolute path to the vault root (second-brain/), used for all direct filesystem reads/writes.
# No MCP/istefox dependency for the backend itself — see SPEC.md EDD decisions.
VAULT_PATH=/Users/shayne/Developer/second-brain

# Port the FastAPI backend listens on.
PORT=8000
